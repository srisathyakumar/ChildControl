<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ChildControl" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/kidly_blue</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Use Ghost Gray as the primary surface/background -->
        <item name="colorSurface">@color/ghost_gray</item>
        <item name="android:windowBackground">@color/ghost_gray</item>
        <item name="colorOnSurface">@color/color_on_surface</item>

        <!-- Cards and Variants stay White to pop against the gray -->
        <item name="colorSurfaceVariant">#FFFFFF</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>

    <style name="Theme.ChildControl.NoStatusIcons" parent="Theme.ChildControl">
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <!-- Personal Info Styles -->
    <style name="PersonalInfoItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">20dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="PersonalInfoIconStyle">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">@color/text_primary</item>
    </style>

    <style name="PersonalInfoTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="PersonalInfoLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="PersonalInfoValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="PersonalInfoFooterStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>
