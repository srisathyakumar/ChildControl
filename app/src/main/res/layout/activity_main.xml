<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_margin_top"
        android:fontFamily="@font/baloo"
        android:text="Welcome"
        android:textColor="?attr/colorOnSurface"
        android:textSize="@dimen/welcome_title_size"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/element_spacing_medium"
        android:fontFamily="@font/lexend_deca"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="@dimen/element_spacing_large"
        android:text="Helping parents stay connected and guide their children safely"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="@dimen/text_size_body" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/element_spacing_extra_large"
        android:layout_marginBottom="@dimen/element_spacing_extra_large"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:src="@drawable/welcome" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateAccount"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:fontFamily="@font/lexend_deca"
        android:text="Get Started"
        android:textAllCaps="false"
        android:textSize="@dimen/text_size_body"
        app:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="@dimen/button_corner_radius" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/element_spacing_medium"
        android:layout_marginBottom="@dimen/element_spacing_large"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_deca"
            android:text="Already have an account? "
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_size_body_small" />

        <TextView
            android:id="@+id/btnLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_deca"
            android:text="Log in"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_size_body_small"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>