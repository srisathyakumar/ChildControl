<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStart="@dimen/element_spacing_medium"
            app:contentInsetEnd="@dimen/element_spacing_medium">

            <LinearLayout
                android:id="@+id/childSelector"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/icon_size_medium"
                android:background="@drawable/avatar_bg"
                android:backgroundTint="?attr/colorSurfaceVariant"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/element_spacing_medium"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    app:cardCornerRadius="@dimen/element_spacing_medium"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorPrimary">
                    <TextView
                        android:id="@+id/txtAvatarLetter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="S"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="@dimen/text_size_caption"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/txtChildHeaderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/element_spacing_small"
                    android:text="Satya"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_size_body_small"
                    android:fontFamily="sans-serif-medium" />

                <ImageView
                    android:layout_width="@dimen/element_spacing_medium"
                    android:layout_height="@dimen/element_spacing_medium"
                    android:layout_marginStart="4dp"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Select Child" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnNotifications"
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Notifications" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/avatarContainer"
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_marginStart="@dimen/element_spacing_small"
                    android:src="@drawable/avatar_bg"
                    android:backgroundTint="?attr/colorSurfaceVariant"
                    android:padding="2dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Profile" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/element_spacing_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_h2"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="@dimen/element_spacing_large"/>

            <!-- Usage Summary Card (Hero Card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/usageBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius_large"
                app:strokeWidth="0dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                android:layout_marginBottom="@dimen/element_spacing_large"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/element_spacing_large">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S USAGE"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="@dimen/text_size_caption"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:fontFamily="sans-serif-medium" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/element_spacing_medium">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/screenTimeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2h 15m"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:textSize="@dimen/text_size_h1"
                                android:fontFamily="sans-serif-light" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total screen time"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:alpha="0.7"
                                android:textSize="@dimen/text_size_body_small" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="@dimen/avatar_size"
                            android:layout_height="@dimen/avatar_size"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:padding="0dp"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconTint="?attr/colorOnPrimaryContainer"
                            android:rotation="270"
                            style="@style/Widget.Material3.Button.TonalButton"
                            app:cornerRadius="@dimen/element_spacing_large"
                            android:contentDescription="View Stats" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Location Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/locationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius_large"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                android:layout_marginBottom="@dimen/element_spacing_large"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <fragment
                        android:id="@+id/map"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="180dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/element_spacing_large"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/icon_size_medium"
                            android:layout_height="@dimen/icon_size_medium"
                            app:cardCornerRadius="@dimen/element_spacing_large"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface">
                            <ImageView
                                android:layout_width="@dimen/element_spacing_medium"
                                android:layout_height="@dimen/element_spacing_medium"
                                android:layout_gravity="center"
                                android:src="@drawable/location"
                                app:tint="?attr/colorPrimary"
                                android:contentDescription="Location Icon" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/element_spacing_medium"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/txtLastLocationLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last Location"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/text_size_body"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/txtLocationStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Waiting for location..."
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_size_caption" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/element_spacing_medium"
                            android:layout_height="@dimen/element_spacing_medium"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:rotation="270"
                            android:contentDescription="Go to map" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Device Status Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device Controls"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_body"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/element_spacing_medium"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius_large"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                android:layout_marginBottom="@dimen/element_spacing_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/element_spacing_large">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icDeviceBg"
                            android:layout_width="@dimen/avatar_size"
                            android:layout_height="@dimen/avatar_size"
                            app:cardCornerRadius="@dimen/element_spacing_medium"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="?attr/colorSurface">
                            <ImageView
                                android:id="@+id/icDevice"
                                android:layout_width="@dimen/element_spacing_large"
                                android:layout_height="@dimen/element_spacing_large"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="?attr/colorOnSurfaceVariant"
                                android:contentDescription="Device Icon" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icDeviceBg"
                            android:layout_marginStart="@dimen/element_spacing_medium"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/childDeviceName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Samsung Galaxy S21"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/text_size_body"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/txtBattery"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="85% • Online"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_size_caption" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/btnLockDeviceSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorSurface"
                        android:alpha="0.5"
                        android:layout_marginVertical="@dimen/element_spacing_large" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLimits"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/element_spacing_small"
                            android:text="Daily limits"
                            app:icon="@android:drawable/ic_menu_recent_history"
                            app:cornerRadius="@dimen/element_spacing_medium"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBedtime"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/element_spacing_small"
                            android:text="Bedtime"
                            app:icon="@android:drawable/ic_menu_month"
                            app:cornerRadius="@dimen/element_spacing_medium"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        app:elevation="8dp"
        app:menu="@menu/bottom_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>