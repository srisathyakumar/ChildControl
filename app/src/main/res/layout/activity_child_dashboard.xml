<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/txtHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Kidly"
                android:textColor="?attr/colorOnSurface"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

            <FrameLayout
                android:id="@+id/avatarContainer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/avatar_bg"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/txtAvatarLetter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="U"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Screen Time Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtScreenTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h 0m"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's screen time"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/deviceStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device Protected"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/locationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Location: Active"
                        android:layout_marginTop="12dp"
                        android:drawablePadding="12dp"
                        app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                        app:drawableTint="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/usageStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Usage Monitoring: Active"
                        android:layout_marginTop="8dp"
                        android:drawablePadding="12dp"
                        app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
                        app:drawableTint="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/accessibilityStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="App Blocking: Active"
                        android:layout_marginTop="8dp"
                        android:drawablePadding="12dp"
                        app:drawableStartCompat="@android:drawable/ic_lock_lock"
                        app:drawableTint="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnUsage"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="View App Usage"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnEnterCode"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Pair With Parent"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/emergencyBtn"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Emergency Alert"
                app:backgroundTint="@color/google_red" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
