<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Connect to Parent"
        android:textSize="26sp"
        android:textStyle="bold"/>

    <TextView
        android:text="Enter the pairing code from the parent's device"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/etChildName"
        android:hint="Child Name"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/etPairCode"
        android:hint="Pair Code"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btnPairNow"
        android:text="Pair Device"
        android:layout_marginTop="20dp"/>

</LinearLayout>